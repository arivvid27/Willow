# Root .gitignore for Willow

# ── Node / frontend dependencies ────────────────────────────────
node_modules/
/.pnp
.pnp.js

# Testing / coverage
coverage/

# Next.js build output
frontend/.next/
frontend/out/

# Generic builds
build/
dist/

# Backend virtualenvs
backend/.venv/
venv/

# Misc
.DS_Store
*.pem

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local env files
.env
.env*.local
frontend/.env*
backend/.env*

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Cursor / IDE
.cursor/
.vscode/
