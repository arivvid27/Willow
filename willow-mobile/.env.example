# Willow Mobile — Environment Variables
# Copy to .env and fill in before running

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:8000
# NOTE: Use your machine's local network IP (e.g. 192.168.1.x), NOT localhost,
# because Android emulators/devices can't reach your Mac's localhost.
# Run: ipconfig (Windows) or ifconfig (Mac/Linux) to find your IP.
