# ============================================================
#  Willow — Environment Variables
#  Copy this to:
#    backend/.env       (for FastAPI)
#    frontend/.env.local (for Next.js)
#  Fill in ALL values before running.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found at: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Google Gemini ─────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Frontend ──────────────────────────────────────────────────
# URL of your running FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
