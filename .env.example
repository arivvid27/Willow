# ============================================================
#  Willow — Environment Variables
#  Copy to: frontend/.env.local
#  All keys go in ONE file now — no separate backend needed.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found at: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Google Gemini ─────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
# NOTE: No NEXT_PUBLIC_ prefix — this stays server-side only (secure)
GEMINI_API_KEY=your-gemini-api-key

# ── Site URL (set this after deploying to Vercel) ─────────────
# Your Vercel deployment URL without https:// e.g. willow.vercel.app
# Only needed for server-side fetch calls — leave blank for local dev
NEXT_PUBLIC_SITE_URL=
